# kubelm environment file (template).
#
# Copy to .env (gitignored) and fill in the keys you actually use:
#     cp .env.example .env
#
# The CLI does not auto-load this file. Source it into your shell before
# running, or use direnv:
#
#     set -a; source .env; set +a
#     uv run python -m eval.scenarios run ...
#
# Never commit .env. (Already in .gitignore.)


# ---- OpenAI (Phase 3 cloud frontier baseline) ----
# Used by --backend-url https://api.openai.com/v1 with --model gpt-4o-mini,
# gpt-4o, etc. The runner reads $OPENAI_API_KEY when --api-key is not passed.
OPENAI_API_KEY=


# ---- OpenRouter (Anthropic, Mistral, Gemini, etc. via OpenAI-compat shim) ----
# OpenRouter exposes most frontier models through the OpenAI Chat Completions
# format, which our OpenAICompatBackend already speaks. Use with:
#     --backend-url https://openrouter.ai/api/v1 \
#     --model anthropic/claude-sonnet-4.6  (or anthropic/claude-opus-4.7, etc.)
#     --api-key $OPENROUTER_API_KEY
# OPENROUTER_API_KEY=


# ---- Anthropic (native, not used yet) ----
# Anthropic's native API does not match OpenAI's tool-call format, so kubelm
# does not have a native Anthropic backend in v0.1. Use OpenRouter above for
# Claude. Reserved here for if/when a native backend lands.
# ANTHROPIC_API_KEY=


# ---- Ollama (no key; URL override only) ----
# Ollama needs no key. Override the URL only if you run it on a non-default
# host or port. The runner takes --backend-url directly; this var is just a
# convenience for shell aliases.
# OLLAMA_BASE_URL=http://localhost:11434/v1


# ---- Hugging Face (for Phase 4/5 dataset and model downloads) ----
# Only needed once we start pulling base models or pushing trained adapters.
# Not used by the eval harness in v0.1.
# HF_TOKEN=
